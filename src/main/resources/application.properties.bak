# ================================================================
#  MediNear v4 – application.properties
#  PostgreSQL: username=postgres  password=akhil1101
#  Redis: runs on localhost:6379 (default, no password)
#  Set GOOGLE_MAPS_API_KEY and ANTHROPIC_API_KEY as env vars
#  or replace the placeholders directly below.
# ================================================================
spring.application.name=mednear
server.port=8080

# ── PostgreSQL ───────────────────────────────────────────────────
spring.datasource.url=jdbc:postgresql://localhost:5432/MedNear
spring.datasource.username=postgres
spring.datasource.password=akhil1101
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=2
spring.datasource.hikari.connection-timeout=30000

# ── JPA / Hibernate ──────────────────────────────────────────────
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.open-in-view=false

# ── Redis Cache ──────────────────────────────────────────────────
spring.data.redis.host=localhost
spring.data.redis.port=6379
# spring.data.redis.password=   # uncomment if your Redis has a password
spring.cache.type=redis
spring.cache.redis.time-to-live=300000
# TTL = 5 minutes (300000 ms). Searches older than 5 min re-hit the DB.
# Cache-aside: first search → DB + cache. Next 1000 searches → Redis only.

# ── JWT ──────────────────────────────────────────────────────────
mednear.app.jwtSecret=TWVkaU5lYXJTdXBlclNlY3JldEp3dEtleUZvckhTMjU2QWxnb3JpdGhtTWluaW11bTI1NkJpdHMhIQ==
mednear.app.jwtExpirationMs=86400000

# ── Search defaults ──────────────────────────────────────────────
mednear.search.default-radius-km=5.0
mednear.search.max-radius-km=50.0
mednear.search.default-page-size=10
mednear.search.max-page-size=50

# ── Google Maps Platform ─────────────────────────────────────────
# Get from: https://console.cloud.google.com
# Enable: Directions API, Geocoding API, Maps Static API
google.maps.api-key=${GOOGLE_MAPS_API_KEY:YOUR_GOOGLE_MAPS_KEY_HERE}
google.maps.base-url=https://maps.googleapis.com

# ── Anthropic Claude AI ──────────────────────────────────────────
# Get from: https://console.anthropic.com
anthropic.api-key=${ANTHROPIC_API_KEY:YOUR_ANTHROPIC_KEY_HERE}
anthropic.api-url=https://api.anthropic.com
anthropic.model=claude-sonnet-4-20250514
anthropic.max-tokens=1024

# ── Logging ──────────────────────────────────────────────────────
logging.level.com.mednear=INFO
logging.level.org.springframework.security=WARN
logging.level.org.hibernate.SQL=WARN
logging.level.org.springframework.cache=DEBUG
